# ============================================
# Image3 — 图像生成 API 配置
# 复制此文件为 .env 后填入实际值
#   cp .env.example .env
# ============================================

# --- MatPool (矩池云) — 推荐默认 ---
# 获取 Key: https://token.matpool.com
# 可用模型: GPT-Image-2, stable-diffusion-3.5-large, flux-1.1-pro
IMAGE_API_KEY=sk-your-matpool-api-key

# --- 模型选择 ---
# 默认用 GPT-Image-2，可切换为:
#   flux-1.1-pro          — FLUX Pro，质量最高
#   stable-diffusion-3.5  — SD3.5，开源标杆
IMAGE_MODEL=GPT-Image-2

# --- 自定义 API 地址（通常不需要改） ---
# IMAGE_API_BASE=https://token.matpool.com

# --- OpenAI DALL-E（可选，用的时候在命令行指定 --provider openai） ---
# OPENAI_API_KEY=sk-your-openai-key

# --- 输出目录（可选，默认 ./output） ---
# IMAGE_OUTPUT_DIR=./output
